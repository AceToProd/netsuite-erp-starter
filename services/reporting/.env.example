# reporting env (ace-engine injects PORT + ERP_CORE_URL + REDIS_URL at runtime).
PORT=3000
NODE_ENV=development

# Where the Java ERP core is reachable.
ERP_CORE_URL=http://localhost:8080

# Optional Redis for caching aggregations. Leave unset to use the in-memory
# cache fallback (zero-infra local dev).
# REDIS_URL=redis://localhost:6379
