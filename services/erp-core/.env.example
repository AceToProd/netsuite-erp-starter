# erp-core env (ace-engine injects PORT + DATABASE_URL at runtime).
#
# Zero-infra local dev: leave DATABASE_URL unset to use the embedded H2 database.
# To use Postgres, set DATABASE_URL to either form:
#   postgres://user:password@host:5432/erp     (cloud / Heroku style — auto-parsed)
#   jdbc:postgresql://host:5432/erp             (used verbatim)
PORT=8080
# DATABASE_URL=postgres://erp:erp@localhost:5432/erp

# Set SEED_DEMO=0 to skip inserting demo customers/items/orders on startup.
SEED_DEMO=1
