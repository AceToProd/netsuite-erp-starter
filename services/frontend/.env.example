# frontend env (ace-engine injects PORT + VITE_API_TARGET at runtime).
# VITE_PORT / PORT controls the dev server port (default 5174).
VITE_PORT=5174

# Where the reporting gateway is reachable. In dev the Vite proxy forwards
# /api -> this target, so the SPA calls a single relative base URL (/api).
VITE_API_TARGET=http://localhost:3000
